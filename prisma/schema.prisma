// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Database is Neon (serverless PostgreSQL). The connection string is supplied
// at runtime via the driver adapter (see src/lib/prisma.ts) and to the Prisma
// CLI via prisma.config.ts (DATABASE_URL).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
