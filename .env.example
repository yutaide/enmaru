# Database — Neon (serverless PostgreSQL) connection string.
# Local dev points at a dev Neon branch. Use the *direct* (unpooled) endpoint here:
# `prisma migrate` needs session features the pooler doesn't support, and local
# dev doesn't need pooling. The *pooled* endpoint (host contains "-pooler") is for
# serverless runtimes and is set as a Netlify env var for production, not here.
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Storage — Cloudflare R2 (S3-compatible). Local dev uses a dev bucket;
# production is set as a Netlify env var.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-dev-bucket-name"

# Auth — Logto Cloud. Local dev uses a dev tenant/app; production is set as a
# Netlify env var. LOGTO_BASE_URL is this app's own base URL (used to build the
# sign-in callback {LOGTO_BASE_URL}/callback) — set it WITHOUT a trailing slash.
# LOGTO_COOKIE_SECRET must be a long random string (e.g. `openssl rand -base64 32`).
LOGTO_ENDPOINT="https://your-tenant.logto.app/"
LOGTO_APP_ID="your-logto-app-id"
LOGTO_APP_SECRET="your-logto-app-secret"
LOGTO_BASE_URL="http://localhost:3000"
LOGTO_COOKIE_SECRET="replace-with-a-long-random-string"

# E2E (Playwright) — base URL of the app under test.
E2E_BASE_URL=http://localhost:3000
